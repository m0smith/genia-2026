{
  "language_version": "0.1.8-prototype",
  "core_ir_version": "0.1.0",
  "core_ir_contract": {
    "minimal_portable_node_families": [
      "IrLiteral",
      "IrOptionNone",
      "IrOptionSome",
      "IrVar",
      "IrQuote",
      "IrDelay",
      "IrQuasiQuote",
      "IrUnquote",
      "IrUnquoteSplicing",
      "IrUnary",
      "IrBinary",
      "IrPipeline",
      "IrCall",
      "IrExprStmt",
      "IrBlock",
      "IrList",
      "IrMap",
      "IrSpread",
      "IrCaseClause",
      "IrCase",
      "IrLambda",
      "IrAssign",
      "IrFuncDef",
      "IrImport"
    ],
    "minimal_portable_pattern_families": [
      "IrPatLiteral",
      "IrPatBind",
      "IrPatWildcard",
      "IrPatRest",
      "IrPatTuple",
      "IrPatList",
      "IrPatMap",
      "IrPatGlob",
      "IrPatSome",
      "IrPatNone"
    ],
    "host_local_post_lowering_nodes": [
      "IrListTraversalLoop"
    ],
    "contract_doc": "docs/architecture/core-ir-portability.md"
  },
  "required_capabilities": [
    "parser",
    "ast_lowering",
    "core_ir_eval",
    "cli_file_mode",
    "cli_command_mode",
    "prelude_autoload",
    "doc_help",
    "shared_spec_runner"
  ],
  "optional_capabilities": [
    "cli_pipe_mode",
    "repl",
    "flow_phase_1",
    "http_server",
    "allowlisted_host_interop",
    "refs",
    "process_primitives",
    "bytes_json_zip",
    "debugger_stdio"
  ],
  "shared_prelude_paths": [
    "src/genia/std/prelude"
  ],
  "host_status": {
    "implemented_hosts": [
      "python"
    ],
    "live_python_source": [
      "src/genia",
      "tests",
      "src/genia/std/prelude"
    ],
    "scaffolded_host_directories": [
      "hosts/python"
    ],
    "planned_hosts": [
      "node",
      "java",
      "rust",
      "go",
      "cpp"
    ],
    "generic_spec_runner": "scaffolded"
  },
  "host_test_contract": {
    "parse": {
      "input": "source string",
      "output": "AST JSON"
    },
    "lower": {
      "input": "source string",
      "output": "minimal portable Core IR JSON",
      "optional_host_local_output": "optional optimized host-local IR JSON payload"
    },
    "eval": {
      "input": "source string",
      "stdin": "optional string input",
      "argv": "optional string list",
      "output": "JSON with result, stdout, stderr, and normalized error data when present"
    },
    "cli": {
      "input": "argv list plus optional stdin string",
      "output": "JSON with stdout, stderr, exit_code, and normalized error data when present"
    }
  },
  "browser_runtime_adapter": {
    "status": "scaffolded",
    "implemented_hosts": [],
    "planned_hosts": [
      "python-backend-service",
      "javascript-browser-native",
      "rust-wasm-browser-native"
    ],
    "contract_docs": [
      "docs/browser/README.md",
      "docs/browser/PLAYGROUND_ARCHITECTURE.md",
      "docs/browser/RUNTIME_ADAPTER_CONTRACT.md"
    ],
    "notes": "Scaffold contract only in this phase; not an implemented browser runtime host capability yet."
  },
  "canonical_docs": [
    "AGENTS.md",
    "GENIA_STATE.md",
    "GENIA_RULES.md",
    "GENIA_REPL_README.md",
    "README.md",
    "docs/book",
    "docs/host-interop/HOST_INTEROP.md",
    "docs/host-interop/HOST_PORTING_GUIDE.md",
    "docs/host-interop/HOST_CAPABILITY_MATRIX.md",
    "docs/browser/README.md",
    "docs/browser/PLAYGROUND_ARCHITECTURE.md",
    "docs/browser/RUNTIME_ADAPTER_CONTRACT.md",
    "docs/architecture/core-ir-portability.md",
    "docs/architecture/pipeline-ir-host-integration.md",
    "tools/spec_runner/README.md"
  ]
}
