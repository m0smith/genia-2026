[
  {
    "id": "core-min-unwrap-or",
    "source": "unwrap_or(\"unknown\", {user: {name: \"Genia\"}} |> get(\"user\") |> get(\"name\"))",
    "expected_result": "\"Genia\""
  },
  {
    "id": "core-min-fields-nth-parse",
    "source": "fields(\"a b c d 5 x\") |> nth(5) |> parse_int |> unwrap_or(0)",
    "expected_result": "5"
  },
  {
    "id": "core-min-keep-some",
    "source": "[\"10\", \"oops\", \"20\"] |> lines |> keep_some(parse_int) |> collect",
    "expected_result": "[10, 20]"
  },
  {
    "id": "core-min-keep-some-else",
    "source": "[\"10\", \"oops\", \"20\"] |> lines |> keep_some_else(parse_int, log) |> collect",
    "expected_result": "[10, 20]"
  },
  {
    "id": "core-min-sum-after-keep-some",
    "source": "[\"10\", \"oops\", \"20\"] |> lines |> keep_some(parse_int) |> collect |> sum",
    "expected_result": "30"
  },
  {
    "id": "core-min-flow-tee-zip",
    "source": "[\"a\", \"b\"] |> lines |> tee |> zip |> collect",
    "expected_result": "[[\"a\", \"a\"], [\"b\", \"b\"]]"
  },
  {
    "id": "core-min-flow-evolve",
    "source": "evolve(4) |> scan((state, _) -> [state + 1, state + 1], 0) |> collect",
    "expected_result": "[1, 2, 3, 4]"
  },
  {
    "id": "core-min-seeded-rand-int",
    "source": "pair_left(pair) = ([x, _]) -> x\npair_right(pair) = ([_, x]) -> x\n\nr0 = rng(7)\ns1 = rand_int(r0, 10)\nr1 = pair_left(s1)\nv1 = pair_right(s1)\ns2 = rand_int(r1, 10)\n[v1, pair_right(s2)]",
    "expected_result": "[8, 7]"
  },
  {
    "id": "core-shell-stage-upper",
    "source": "\"hello\" |> $(tr a-z A-Z)",
    "expected_result": "\"HELLO\""
  },
  {
    "id": "core-min-annotation-doc",
    "source": "@doc \"Adds one to x.\"\ninc(x) -> x + 1\ndoc(\"inc\")",
    "expected_result": "\"Adds one to x.\""
  },
  {
    "id": "core-actor-call-reply",
    "source": "handler(state, msg, _ctx) = [\"reply\", state + msg, state + msg]\na = actor(0, handler)\nactor_call(a, 5)",
    "expected_result": "5"
  },
  {
    "id": "core-actor-call-ok",
    "source": "handler(state, msg, _ctx) = [\"ok\", state + msg]\na = actor(0, handler)\nactor_call(a, 3)",
    "expected_result": "3"
  },
  {
    "id": "core-actor-status",
    "source": "handler(state, _msg, _ctx) = [\"ok\", state]\na = actor(0, handler)\nactor_status(a)",
    "expected_result": "\"ready\""
  }
]
