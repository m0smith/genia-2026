n = 0
a = or_else_with(some(3), () -> { n = n + 1 n })
b = or_else_with(none(empty_list), () -> { n = n + 1 n })
record = {user: {address: {zip: "80302"}}}
data = {items: [{name: "A"}, {name: "B"}]}

[
  unwrap_or(0, map_some((x) -> x + 1, some(2))),
  unwrap_or(0, flat_map_some((x) -> some(x + 1), some(2))),
  a,
  b,
  n,
  unwrap_or("unknown", record |> get("user") |> get("address") |> get("zip")),
  unwrap_or("?", data |> get("items") |> nth(0) |> get("name")),
  any?((_) -> some(1), [1]),
  any?((_) -> none, [1])
]
