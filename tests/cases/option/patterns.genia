status(opt) =
  none -> "missing" |
  some(x) -> x

extract_name(opt) =
  some({name}) -> name |
  none -> "?" |
  _ -> "?"

describe(opt) =
  none("empty-list") -> "empty" |
  none("index-out-of-bounds", info) -> info/index |
  none(_) -> "missing" |
  some(v) -> v

[
  status(get("name", {name: "Genia"})),
  status(none),
  extract_name(some({name: "Genia"})),
  extract_name(some({})),
  extract_name(none),
  describe(none("empty-list")),
  describe(none("index-out-of-bounds", {index: 8, length: 2})),
  describe(none("missing-key", {key: "name"})),
  describe(some(3))
]
