status(opt) =
  none -> "missing" |
  some(x) -> x

extract_name(opt) =
  some({name}) -> name |
  _ -> "?"

describe(opt) =
  none(empty_list) -> "empty" |
  none(index_out_of_bounds, info) -> info/index |
  none(_) -> "missing" |
  some(v) -> v

[
  status(get("name", {name: "Genia"})),
  status(none),
  extract_name(some({name: "Genia"})),
  extract_name(some({})),
  extract_name(none),
  describe(none(empty_list)),
  describe(none(index_out_of_bounds, {index: 8, length: 2})),
  describe(none(missing_key, {key: "name"})),
  describe(some(3))
]
