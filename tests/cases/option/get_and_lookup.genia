record = {a: 3, profile: {name: "Genia"}, empty: nil}
missing = get("b", record)
ctx = unwrap_or({}, absence_context(missing))

[
  unwrap_or(0, get("a", record)),
  is_none?(missing),
  unwrap_or("missing", get("profile", record) |> then_get("name")),
  ctx/key,
  is_some?(get("empty", record)),
  unwrap_or("fallback", get("empty", record)),
  get?("a", record) == get("a", record),
  is_none?(get("a", none)),
  unwrap_or(0, get("a", some({a: 3})))
]
