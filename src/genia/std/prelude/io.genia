write(sink, value) = """
# write

Write the display form of `value` to `sink` without a trailing newline.
""" _write(sink, value)

writeln(sink, value) = """
# writeln

Write the display form of `value` to `sink` followed by a newline.
""" _writeln(sink, value)

flush(sink) = """
# flush

Flush an output sink.
""" _flush(sink)
