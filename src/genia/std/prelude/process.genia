spawn(handler) = """
# spawn

Create a process handle backed by a host-thread mailbox worker.
""" _spawn(handler)

send(process, message) = """
# send

Enqueue `message` for a process mailbox.
""" _send(process, message)

process_alive?(process) = """
# process_alive?

Check whether a process worker is still alive.
""" _process_alive?(process)
