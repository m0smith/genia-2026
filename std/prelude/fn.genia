apply(f, args) = """
# apply

Call `f` with a list of positional arguments.
""" f(..args)

compose(..fns) = """
# compose

Compose functions right-to-left into one callable.
""" (..args) -> compose_apply(fns, args)

compose_apply(fns, args) =
  ([f], args) -> apply(f, args) |
  ([f, ..rest], args) -> f(compose_apply(rest, args))
