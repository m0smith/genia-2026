inc(x) = x + 1

dec(x) = x - 1

mod(a, b) = a % b

abs(x) =
  (x) ? x < 0 -> 0 - x |
  (x) -> x

min(a, b) =
  (a, b) ? a <= b -> a |
  (a, b) -> b

max(a, b) =
  (a, b) ? a >= b -> a |
  (a, b) -> b

reduce(f, acc, xs) =
  (f, acc, []) -> acc |
  (f, acc, [x, ..rest]) -> reduce(f, f(acc, x), rest)

sum(xs) = reduce((acc, x) -> acc + x, 0, xs)
