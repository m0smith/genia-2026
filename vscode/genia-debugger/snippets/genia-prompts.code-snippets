  "Genia Implementation Prompt": {
    "prefix": "genia.impl",
    "body": [
      "Follow docs/process/implementation-prompt.md",
      "",
      "CHANGE NAME: ${1:change-name}",
      "",
      "Work ONLY on:",
      "- ${2:src/genia/file.py}",
