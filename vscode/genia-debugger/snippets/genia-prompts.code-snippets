      "- ${1:docs/design/a.md}",
      "- ${2:docs/design/b.md}",
      "- ${3:docs/design/c.md}",
      "",
      "Do not consider any files outside this list."
    ],
    "description": "Genia doc distillation prompt"
  },

  "Genia Commit Prompt": {
    "prefix": "genia.commit",
    "body": [
      "Follow docs/process/commit-prompt.md",
      "",
      "CHANGE NAME: ${1:change-name}",
      "",
      "Prepare only the commit/PR summary.",
      "Do not modify files."
    ],
    "description": "Genia commit/PR summary prompt"
  }
