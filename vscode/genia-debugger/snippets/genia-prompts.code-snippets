    "prefix": "genia.docs",
    "body": [
      "Follow docs/process/doc-sync-prompt.md",
      "",
      "CHANGE NAME: ${1:change-name}",
      "",
      "Work ONLY on:",
      "- ${2:GENIA_STATE.md}",
      "- ${3:GENIA_RULES.md}",
